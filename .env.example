# ── Ollama ───────────────────────────────────────────────────
# Ollama runs locally — no API key needed
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
VLM_MODEL=llava-phi3

# ── Embeddings ───────────────────────────────────────────────
# "cuda" if you have NVIDIA GPU, "cpu" otherwise
EMBEDDING_DEVICE=cuda
EMBEDDING_MODEL=BAAI/bge-m3

# ── Qdrant ───────────────────────────────────────────────────
# Qdrant runs locally via Docker — no API key needed
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=medrag_docs

# ── Chunking ─────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_CHUNK_SIZE=100

# ── Retrieval ────────────────────────────────────────────────
DENSE_TOP_K=20
SPARSE_TOP_K=20
RERANK_TOP_K=5

# ── PDF Parsing ──────────────────────────────────────────────
EXTRACT_TABLES=true
EXTRACT_IMAGES=true
MIN_IMAGE_SIZE=100

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Debug ────────────────────────────────────────────────────
DEBUG=false